        model: this.model,
        base_url: this.baseUrl,
        schema_name: request.schemaName,
        error: errorMessage
      throw error;
    }
        }
      },
      async (trace) => {
        const targetUrl = `${this.baseUrl}/chat/completions`;
        const startedAt = Date.now();
        let response: Response;

        try {
          response = await fetch(targetUrl, {
            ...createOpenAiCompatibleFetchOptions(targetUrl),
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Authorization: `Bearer ${this.apiKey}`
            },
            body: JSON.stringify({
              model: this.model,
              temperature: 0,
              response_format: {
                type: "json_object"
              },
              messages: [
                {
                  role: "system",
                  content: request.systemPrompt
                },
                {
                  role: "user",
                  content: buildUserMessageContent(request)
                }
              ]
            })
          });
        } catch (error) {
          throw new Error(buildTransportErrorMessage(error));
        }

        const payload = (await response.json()) as ChatCompletionResponse;

        if (!response.ok) {
          throw new Error(payload.error?.message ?? "LLM request failed");
        }

        const content = extractTextContent(payload.choices?.[0]?.message?.content);

        if (!content) {
          const error = new Error("LLM returned an empty response");
          await recordLangfuseModelCall({
            provider: "openai_compatible",
            baseUrl: this.baseUrl,
            model: this.model,
            schemaName: request.schemaName,
            schemaDescription: request.schemaDescription,
            systemPrompt: request.systemPrompt,
            userPrompt: request.userPrompt,
            hasImageInput: Boolean(request.userImageDataUrl),
            durationMs: Date.now() - startedAt,
            status: "error",
            errorMessage: error.message
          });
          throw error;
        }

        let parsed: unknown;
        try {
          parsed = parseJsonFromContent(content);
        } catch (error) {
          await recordLangfuseModelCall({
            provider: "openai_compatible",
            baseUrl: this.baseUrl,
            model: this.model,
            schemaName: request.schemaName,
            schemaDescription: request.schemaDescription,
            systemPrompt: request.systemPrompt,
            userPrompt: request.userPrompt,
            hasImageInput: Boolean(request.userImageDataUrl),
            rawOutput: content,
            durationMs: Date.now() - startedAt,
            status: "error",
            errorMessage: error instanceof Error ? error.message : String(error)
          });
          throw error;
        }

    }
  }
}

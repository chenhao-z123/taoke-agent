# Database
DATABASE_URL="file:./dev.db"

# LLM Provider Configuration
LLM_PROVIDER="openai_compatible"
LLM_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
LLM_MODEL="kimi-k2.5"
LLM_API_KEY="your-api-key-here"

# Langfuse Tracing Configuration (optional but recommended for debugging)
# Get these from your Langfuse project settings
LANGFUSE_SECRET_KEY="your-langfuse-secret-key"
LANGFUSE_PUBLIC_KEY="your-langfuse-public-key" 
LANGFUSE_BASE_URL="https://us.cloud.langfuse.com"

# Set to false to disable shallow logging (recommended when using VPN/proxy)
LANGFUSE_SHALLOW_LOGGING=false